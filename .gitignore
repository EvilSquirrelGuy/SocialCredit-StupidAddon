.gradle
**/build/
!**/src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# environment vars
.env

# macos
.DS_Store

# ignore everything in run (server test env)
run/*

# allow root files
!run/*.*

# allow directories themselves
!run/plugins/
!run/config/

# then allow their contents
!run/plugins/**
!run/config/**

# and finally disallow paper remapped
run/plugins/.*